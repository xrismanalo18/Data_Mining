# Public Supabase project settings. These are safe for browser-side Supabase features.
NEXT_PUBLIC_SUPABASE_URL=https://hamwxevcyrukjbdptteb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_YOUR_KEY

# Required for this app's backend upload/save APIs.
# Use the Supabase pooled Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI.
# For Vercel/serverless, prefer the transaction pooler URI on port 6543.
POSTGRES_URL=postgresql://postgres.hamwxevcyrukjbdptteb:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Optional app-owned override. Prefer this when a Vercel integration manages
# POSTGRES_URL and has stale credentials after a database password reset.
PROCESS_MINING_DATABASE_URL=

# These names are also accepted by the app:
# DATABASE_URL=
# SUPABASE_POSTGRES_URL=
# SUPABASE_DATABASE_URL=
# SUPABASE_DB_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
BLOB_READ_WRITE_TOKEN=

# Optional. If not set, original uploads are skipped and parsed event rows are still stored in Postgres.

# Optional AI chart planner. Keep the API key server-only and mark it Sensitive in Vercel.
# Without this key, dashboard commands use the built-in local planner.
OPENAI_API_KEY=
OPENAI_CHART_MODEL=gpt-5.6
